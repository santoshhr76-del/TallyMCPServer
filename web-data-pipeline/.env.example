# Copy this file to .env and fill in your API key
# cp .env.example .env

# Required: Anthropic API key (get one at https://platform.claude.com/)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: use Amazon Bedrock instead of Anthropic directly
# CLAUDE_CODE_USE_BEDROCK=1

# Optional: use Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
