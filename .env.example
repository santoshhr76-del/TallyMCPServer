# ── TallyPrime MCP Server — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Tally Gateway connection ──────────────────────────────────────────────
# URL of your TallyPrime Gateway Server.
# Options:
#   Local only:         http://localhost:9000
#   Cloudflare Tunnel:  https://tally.yourdomain.com
#   ngrok:              https://abc123.ngrok-free.app
#   Direct IP/VPN:      http://192.168.1.100:9000
TALLY_URL=http://localhost:9000

# HTTP request timeout in seconds
TALLY_TIMEOUT=30

# ── MCP HTTP Server ───────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional API key for securing your cloud MCP endpoint.
# Clients must send: Authorization: Bearer <key>
# Leave blank to disable authentication (not recommended in production).
MCP_API_KEY=change-me-to-a-strong-random-secret

GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
UPI_VPA=your-upi-id@bank